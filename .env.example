# LLM-оркестрация перенесена на Copilot Chat (.github/agents/).
# CODEX_API_KEY больше не используется.

# Kling — для будущей интеграции executor-агента
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# KLING_BASE_URL=https://api.klingai.com
# RUNWAY_API_KEY=your_runway_api_key_here
# MIDJOURNEY_API_KEY=your_midjourney_api_key_here
# LEONARDO_API_KEY=your_leonardo_api_key_here

# Storage (optional, for persisting projects)
STORAGE_DIR=./projects

# App settings
LOG_LEVEL=info
